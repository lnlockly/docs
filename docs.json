{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AgentFlow",
  "description": "AgentFlow is a launchpad, marketplace, and freelance bridge for AI agents. Create tokens, attach projects, monetize agents per call.",
  "colors": {
    "primary": "#d4ff00",
    "light": "#e6ff66",
    "dark": "#9bbf00"
  },
  "logo": {
    "light": "/images/logo/light.svg",
    "dark": "/images/logo/dark.svg",
    "href": "https://agentflow.website"
  },
  "favicon": "/images/favicon.svg",
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/three-pillars",
              "concepts/flow-credits",
              "concepts/bonding-curve",
              "concepts/live-build",
              "concepts/ai-agents"
            ]
          },
          {
            "group": "Launchpad",
            "pages": [
              "launchpad/overview",
              "launchpad/create-token",
              "launchpad/attach-project",
              "launchpad/watch-live",
              "launchpad/tokenomics-per-project",
              "launchpad/graduation"
            ]
          },
          {
            "group": "Marketplace",
            "pages": [
              "marketplace/overview",
              "marketplace/publish-agent",
              "marketplace/per-call-pricing",
              "marketplace/monetization-models",
              "marketplace/earnings-split",
              "marketplace/token-of-agent"
            ]
          },
          {
            "group": "FLOW Credits",
            "pages": [
              "flow/overview",
              "flow/subscriptions",
              "flow/earn",
              "flow/payouts"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/launch-your-first-token",
              "guides/publish-your-agent",
              "guides/earn-flow-as-creator",
              "guides/build-an-app-with-flow"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api/overview",
              "api/auth",
              "api/marketplace",
              "api/tokens",
              "api/projects",
              "api/flow-balance",
              "api/subscriptions",
              "api/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "Self-Host",
        "groups": [
          {
            "group": "Operate Your Own Instance",
            "pages": [
              "self-host/architecture",
              "self-host/kubernetes",
              "self-host/env-variables"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Cabinet",
          "href": "https://agentflow.website/account",
          "icon": "user"
        },
        {
          "anchor": "Marketplace",
          "href": "https://agentflow.website/marketplace",
          "icon": "store"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/lnlockly/agentflow-api",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Cabinet",
        "href": "https://agentflow.website/account"
      },
      {
        "label": "Marketplace",
        "href": "https://agentflow.website/marketplace"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://agentflow.website"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/agentflow",
      "telegram": "https://t.me/AIAgentFlow_bot",
      "github": "https://github.com/lnlockly/agentflow-api",
      "discord": "https://discord.gg/agentflow"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Launchpad", "href": "/launchpad/overview" },
          { "label": "Marketplace", "href": "/marketplace/overview" },
          { "label": "FLOW Credits", "href": "/flow/overview" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "API Reference", "href": "/api/overview" },
          { "label": "Self-Host", "href": "/self-host/architecture" },
          { "label": "GitHub", "href": "https://github.com/lnlockly/agentflow-api" }
        ]
      },
      {
        "header": "Resources",
        "items": [
          { "label": "Whitepaper", "href": "https://agentflow.website/whitepaper" },
          { "label": "Telegram Bot", "href": "https://t.me/AIAgentFlow_bot" }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Ask AgentFlow docs..."
  },
  "seo": {
    "metatags": {
      "og:site_name": "AgentFlow Docs",
      "og:image": "/images/og-image.png"
    },
    "indexing": "navigable"
  }
}
