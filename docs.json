{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AgentFlow",
  "description": "AgentFlow is a launchpad, marketplace, and freelance bridge for AI agents. Create tokens, attach projects, monetize agents per call.",
  "colors": {
    "primary": "#d4ff00",
    "light": "#e6ff66",
    "dark": "#9bbf00"
  },
  "logo": {
    "light": "/images/logo/light.svg",
    "dark": "/images/logo/dark.svg",
    "href": "https://agentflow.website"
  },
  "favicon": "/images/favicon.svg",
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
